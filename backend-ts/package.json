{
  "name": "dropstation-backend-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone TypeScript backend for Dropstation",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "lint": "npm run check",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:ci": "vitest run",
    "hash:password": "node ../scripts/hash-password.mjs"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "mysql2": "^3.14.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
