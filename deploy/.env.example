# dropstation/deploy/.env.example
#
# Copy to .env and fill in values before starting the stack:
#   cp .env.example .env
#   docker compose -f docker-compose.yml up -d
#
# This file is safe to commit. The .env file is gitignored.

# ── Server ────────────────────────────────────────────────────────────────────

# OPTIONAL — interface the app listens on inside the container.
# Must stay 0.0.0.0 so Docker's port mapping can reach the process.
# External exposure is controlled by the ports binding in docker-compose.yml
# (127.0.0.1:3003:3001), which restricts access to localhost only.
# Use Apache mod_proxy to expose the service to external users.
HOST=0.0.0.0

# OPTIONAL — port the app listens on inside the container.
PORT=3001

# OPTIONAL — JWT token TTL in seconds (default 8 hours).
AUTH_TOKEN_TTL_SECONDS=28800

# ── Auth ──────────────────────────────────────────────────────────────────────

# REQUIRED — secret used to sign JWT tokens. Use a long random string.
AUTH_TOKEN_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────

# REQUIRED — hostname of the MySQL database.
DB_HOST=

# OPTIONAL — database port.
DB_PORT=3306

# REQUIRED — database name.
DB_NAME=dropstation

# REQUIRED — database user.
DB_USER=

# REQUIRED — database password.
DB_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────

# REQUIRED — comma-separated list of allowed frontend origins.
CORS_ORIGINS=https://waterpanel.maxistar.me,https://waterapp.maxistar.me
